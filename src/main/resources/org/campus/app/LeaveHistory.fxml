<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="450.0" prefWidth="650.0" spacing="15.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fx/1" fx:controller="org.controller.LeaveHistoryController">
    <children>
        <!-- Header Section -->
        <VBox spacing="5.0">
            <children>
                <Label text="📋 Active &amp; Past Leave Applications" textFill="#1A202C">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Label text="Showing historically logged leave status matching your student account session." textFill="#718096">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <!-- Table View Component -->
        <TableView fx:id="tableLeaveHistory" VBox.vgrow="ALWAYS" style="-fx-background-radius: 6px; -fx-border-radius: 6px; -fx-border-color: #E2E8F0;">
            <columns>
                <TableColumn fx:id="colType" prefWidth="150.0" text="Type of Leave" />
                <TableColumn fx:id="colStart" prefWidth="100.0" text="Start Date" />
                <TableColumn fx:id="colEnd" prefWidth="100.0" text="End Date" />
                <TableColumn fx:id="colReason" prefWidth="150.0" text="Reason / Details Summary" />
                <TableColumn fx:id="colRef" prefWidth="115.0" text="Reference ID" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Footer / Action Area -->
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button fx:id="btnClose" mnemonicParsing="false" onAction="#handleCloseWindow" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #E2E8F0; -fx-text-fill: #4A5568; -fx-background-radius: 4px; -fx-cursor: hand;" text="Close">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
</VBox>