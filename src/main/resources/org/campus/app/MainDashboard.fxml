<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<SplitPane dividerPositions="0.55" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://fxml.com/fxml/1" fx:controller="org.controller.MainDashboardController">
    <items>
        <!-- Left Pane: AI Chat Interface -->
        <AnchorPane minWidth="400.0">
            <children>
                <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label text="Campus Policy Assistant">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <ScrollPane fx:id="scrollChat" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vBoxChatContainer" spacing="10.0" />
                            </content>
                        </ScrollPane>
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="txtChatInput" onAction="#handleSendMessage" promptText="Ask about leave rules (e.g., medical leave criteria)..." HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnSendMessage" mnemonicParsing="false" onAction="#handleSendMessage" style="-fx-background-color: #007AFF; -fx-text-fill: white; -font-weight: bold;" text="Send" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>

        <!-- Right Pane: Leave Document Form Layout -->
        <AnchorPane minWidth="350.0" style="-fx-background-color: #F5F5F7;">
            <children>
                <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Leave Application Form">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Button fx:id="btnGenerateDraft" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLoadTemplate" style="-fx-background-color: #34C759; -fx-text-fill: white; -font-weight: bold;" text="✨ Pull Template via MCP" />

                        <VBox spacing="5.0">
                            <Label text="Type of Leave" />
                            <ComboBox fx:id="comboLeaveType" maxWidth="Infinity" promptText="Select Type" />
                        </VBox>

                        <HBox spacing="10.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Start Date" />
                                        <DatePicker fx:id="dateStart" maxWidth="Infinity" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="End Date" />
                                        <DatePicker fx:id="dateEnd" maxWidth="Infinity" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Reason / Justification" />
                                <TextArea fx:id="txtReason" prefHeight="120.0" promptText="Provide context for your absence..." wrapText="true" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <Button fx:id="btnSubmit" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSubmitLeave" style="-fx-background-color: #007AFF; -fx-text-fill: white; -font-weight: bold;" text="Formally Submit Application">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>

                        <Button fx:id="btnViewHistory" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleViewActiveLeaves" style="-fx-background-color: #8E8E93; -fx-text-fill: white; -font-weight: bold;" text="📋 View Active Leaves">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </items>
</SplitPane>